---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import { getCollection } from 'astro:content';
import {
  siteTitle,
  moduleDescriptions,
  moduleTags,
  tracks,
} from '../data/site';

const chapters = await getCollection('chapters');
const bySlug = new Map(chapters.map((c) => [c.data.slug, c]));

const base = `${import.meta.env.BASE_URL}`.replace(/\/$/, '');
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'StackSense',
  alternateName: siteTitle,
  url: `${siteUrl}/`,
  description:
    '面向系统工程师的 AI / Data Infra 学习地图：把基础语言、操作系统、数据 / AI 栈、工程实践和延伸阅读放到一张图上，按主题跳读。',
  inLanguage: 'zh-CN',
};

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: chapters.length,
  itemListElement: tracks.flatMap((t, ti) =>
    t.slugs.map((slug, si) => {
      const c = bySlug.get(slug);
      return {
        '@type': 'ListItem',
        position: ti * 10 + si + 1,
        url: `${siteUrl}/${slug}/`,
        name: c?.data.title ?? slug,
      };
    }),
  ),
};
---

<Base
  ogImage="/og/home.png"
  pageType="website"
  jsonLd={[websiteLd, itemListLd]}
>
  <div class="page">
    <header class="topbar">
      <a href="#top" class="brand">
        <Logo size={22} class="brand-logo" />
        <span class="brand-name">StackSense</span>
      </a>
      <nav class="topnav" aria-label="Sections">
        {tracks.map((t) => (
          <a href={`#${t.id}`}>{t.sub}</a>
        ))}
      </nav>
    </header>

    <section class="hero">
      <span class="eyebrow">A study map for systems engineers</span>
      <h1>AI / Data Infra <span class="accent">知识地图</span></h1>
      <p class="lede">
        把语言、操作系统、数据栈、AI infra、GPU 编程、工程实践和延伸阅读放到同一张地图上。
      </p>
      <p class="lede">
        每个模块独立成页：介绍、要回答的问题、概念、Lab、资料、工具。按主题跳读，不必从头到尾。
      </p>

      <div class="hero-stats">
        <div>
          <div class="num">{chapters.length}</div>
          <div class="label">modules</div>
        </div>
        <div>
          <div class="num">{tracks.length}</div>
          <div class="label">tracks</div>
        </div>
        <div>
          <div class="num">200+</div>
          <div class="label">resources</div>
        </div>
      </div>
    </section>

    {tracks.map((t, ti) => (
      <section class="track" id={t.id}>
        <header class="track-head">
          <div class="label-col">
            <span class="ord">
              {String(ti + 1).padStart(2, '0')}
              <span class="ord-sep">/</span>
              {String(tracks.length).padStart(2, '0')}
            </span>
            <span class="label">{t.label}</span>
            <span class="sub">{t.sub}</span>
          </div>
          <p class="hint">{t.hint}</p>
        </header>
        <div class="module-grid">
          {t.slugs.map((slug) => {
            const c = bySlug.get(slug);
            if (!c) return null;
            return (
              <a class="module-card" href={`${base}/${slug}/`}>
                <div class="card-top">
                  <span class="tag">{moduleTags[slug]}</span>
                  <span class="arrow">→</span>
                </div>
                <span class="title">{c.data.title}</span>
                <span class="desc">{moduleDescriptions[slug]}</span>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <footer class="site-foot">
      <span>StackSense · {chapters.length} modules · {tracks.length} tracks</span>
      <span>static · astro</span>
    </footer>
  </div>
</Base>
